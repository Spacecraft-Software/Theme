{
    "manifestVersion": 1,
    "id": "spacecraft-software-theme",
    "version": "1.0.0",
    "name": "Spacecraft Software Theme",
    "description": "Industrial dark theme for Azure DevOps boards and pipelines.",
    "publisher": "Mohamed Hammad",
    "icons": {
        "default": "icon.png"
    },
    "links": {
        "home": {
            "uri": "https://SpacecraftSoftware.org"
        }
    },
    "categories": [
        "Azure Pipelines",
        "Azure Boards"
    ],
    "targets": [
        {
            "id": "Microsoft.VisualStudio.Services"
        }
    ],
    "contributions": [
        {
            "id": "spacecraft-software-dark-theme",
            "type": "ms.vss-web.theme",
            "description": "Spacecraft Software Dark Theme",
            "targets": [
                "ms.vss-web.theme-collection"
            ],
            "properties": {
                "name": "Spacecraft Software",
                "uiTheme": "dark",
                "variables": {
                    "background-color": "#000027",
                    "primary-text-color": "#D98E32",
                    "secondary-text-color": "#6272A4",
                    "primary-button-background": "#4B7EB0",
                    "primary-button-text": "#000027",
                    "accent-color": "#FE6B00",
                    "error-color": "#FF5C5C"
                }
            }
        }
    ],
    "files": [
        {
            "path": "icon.png",
            "addressable": true
        }
    ]
}